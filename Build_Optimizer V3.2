                .bo-results-table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 11px; }
                .bo-results-table th, .bo-results-table td { padding: 5px 6px; text-align: left; border: 1px solid #c9a86c; }
                .bo-results-table th { background: #c9a86c; color: #422d09; }
