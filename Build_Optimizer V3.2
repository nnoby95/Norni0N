                .bo-empty-queue { text-align: center; color: #888; padding: 20px; font-style: italic; }
                .bo-position { background: #d4b57a; border-radius: 50%; width: 20px; height: 20px; display: inline-flex; align-items: center; justify-content: center; font-weight: bold; font-size: 10px; }
