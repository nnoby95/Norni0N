                                <span>→</span>
                                <input type="number" id="bo-target-level" placeholder="Szint" min="1" max="30" style="width: 55px;">
                                <button class="btn" onclick="window.BuildOptimizer.addToQueue()">+ Hozzáad</button>
                                <button class="btn btn-danger" onclick="window.BuildOptimizer.clearQueue()">Törlés</button>
                            </div>
                        </div>
                    </div>

                    <div class="bo-section">
                        <h4>Gyors hozzáadás (több szint)</h4>
                        <div class="bo-quick-add">
                            <select id="bo-quick-building">
                                ${Object.entries(buildConf).map(([key, conf]) => 
                                    `<option value="${key}" data-current="${currentBuildings[key] || 0}" data-max="${conf.max_level}">${conf.name}</option>`
                                ).join('')}
                            </select>
                            <input type="number" id="bo-quick-from" placeholder="Ettől" style="width: 50px;">
                            <span>→</span>
                            <input type="number" id="bo-quick-to" placeholder="Eddig" style="width: 50px;">
                            <button class="btn" onclick="window.BuildOptimizer.addMultipleLevels()">Hozzáad</button>
                        </div>
                    </div>

                    <div class="bo-section">
                        <h4>Főhadiszállás optimalizálás</h4>
                        <div class="bo-hq-test">
                            <label>Teszt HQ szintig: 
                                <input type="number" id="bo-hq-test-max" value="${Math.min(currentHQ + 5, 30)}" min="${currentHQ + 1}" max="30" style="width: 55px;">
                            </label>
                            <button class="btn btn-primary" onclick="window.BuildOptimizer.analyze()">🔍 Elemzés</button>
