                .bo-summary.no-save { background: linear-gradient(to bottom, #fff5da 0%, #efe0c0 100%); border-color: #c9a86c; }
                .bo-summary h5 { margin: 0 0 8px 0; color: #1B5E20; }
                .bo-summary.no-save h5 { color: #5d3d0a; }
                .bo-remove-btn { cursor: pointer; color: #c00; font-weight: bold; font-size: 14px; }
                .bo-remove-btn:hover { color: #f00; }
                .bo-move-btn { cursor: pointer; color: #666; font-size: 12px; padding: 0 2px; }
                .bo-move-btn:hover { color: #000; }
