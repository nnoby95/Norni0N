        document.body.insertAdjacentHTML('beforeend', style + html);
        makeDraggable(document.getElementById('buildOptimizer'));
        
        setInterval(() => {
            const el = document.getElementById('bo-server-time');
            if (el) el.textContent = formatDateTime(getServerTime());
        }, 1000);
    }

    function makeDraggable(element) {
        const header = element.querySelector('.bo-header');
        let isDragging = false;
        let offsetX, offsetY;

        header.addEventListener('mousedown', (e) => {
            if (e.target.classList.contains('bo-close')) return;
            isDragging = true;
            offsetX = e.clientX - element.getBoundingClientRect().left;
            offsetY = e.clientY - element.getBoundingClientRect().top;
        });

        document.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            element.style.left = (e.clientX - offsetX) + 'px';
            element.style.top = (e.clientY - offsetY) + 'px';
            element.style.right = 'auto';
        });

        document.addEventListener('mouseup', () => { isDragging = false; });
    }

    function updateBonus(value) {
        const bonus = parseInt(value) || 0;
        worldConfig.buildTimeBonus = Math.max(0, Math.min(99, bonus));
        
        const input = document.getElementById('bo-build-bonus');
        const container = input?.closest('.bo-bonus-input');
        
        if (container) {
            if (bonus > 0) {
                container.classList.add('bo-bonus-active');
                UI.SuccessMessage(`Építési bónusz: ${bonus}% (gyorsabb építés)`);
            } else {
                container.classList.remove('bo-bonus-active');
            }
        }
        
        // Update queue display to show new times
        updateQueueDisplay();
    }

    // =============================================================================
    // INITIALIZATION
    // =============================================================================
    
    window.BuildOptimizer = {
        addToQueue,
        addMultipleLevels,
        removeFromQueue,
        moveUp,
        moveDown,
        clearQueue,
        analyze,
        updateBonus
    };

    await fetchWorldConfig();
    createUI();
    updateQueueDisplay();

    UI.SuccessMessage(`${scriptConfig.name} ${scriptConfig.version} betöltve!`);

})();
